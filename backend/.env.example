# .env 示例 — 复制为 .env 后按需修改
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skill_platform
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=skill-assets
MINIO_SECURE=false
DEBUG=true

# 对外访问 URL
BASE_URL=http://localhost:8000

# ── 管理后台登录凭据（必须修改！）──────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# 用于签发 session token 的密钥，请替换为随机长字符串
ADMIN_SECRET_KEY=change-this-secret-in-production
