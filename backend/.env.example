# .env 示例 — 复制为 .env 后按需修改
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skill_platform
REDIS_URL=redis://localhost:6378/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=tzf1003
MINIO_SECRET_KEY=zf123456
MINIO_BUCKET=skill-assets
MINIO_SECURE=false
DEBUG=true

# 对外访问 URL
BASE_URL=http://localhost:8000

# ── 管理后台登录凭据（必须修改！）──────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# 用于签发 session token 的密钥，请替换为随机长字符串
ADMIN_SECRET_KEY=change-this-secret-in-production


# --- AI API 格式选择: gemini | openai | anthropic ---
AI_API_FORMAT=gemini


# --- Gemini ---
# 在 https://aistudio.google.com/app/apikey 获取
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# 图像处理模型（支持图像输入+输出）
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
# 文本模型（用于纯文本任务）
GEMINI_TEXT_MODEL=gemini-2.0-flash

# --- OpenAI / OpenAI-Compatible ---
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=gpt-4o
# OPENAI_TEXT_MODEL=gpt-4o

# --- Anthropic / Anthropic-Compatible ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_BASE_URL=
# ANTHROPIC_IMAGE_MODEL=claude-opus-4-5
# ANTHROPIC_TEXT_MODEL=claude-opus-4-5

# 前端通过 /minio 反代访问 MinIO（留空则返回绝对 URL）
MINIO_PUBLIC_BASE=/minio